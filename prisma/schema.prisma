generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String    @id @default(cuid())
  name              String?
  email             String?   @unique
  emailVerified     DateTime?
  image             String?
  passwordHash      String?
  role              String    @default("CUSTOMER") // ADMIN | SUPPORT | DESIGNER | CUSTOMER
  firstName         String
  lastName          String
  addressStreet     String?
  addressCity       String?
  addressPostalCode String?
  addressCountry    String?
  preferredLanguage String    @default("es") // es, cat
  deletedAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  orders            Order[]
  carts             Cart[]
  seller            Seller?
}

model Role {
  id          String @id @default(uuid())
  name        String @unique
  description String @default("")
}

model Seller {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id])
  status      String    @default("active")
  deletedAt   DateTime?
  products    Product[]
  orders      Order[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
}

model Product {
  id             String                 @id @default(cuid())
  basePrice      Decimal
  currency       String                 @default("EUR")
  sellerId       String
  seller         Seller                 @relation(fields: [sellerId], references: [id])
  status         String                 @default("ACTIVE") // DRAFT | ACTIVE | ARCHIVED
  categoryId     String?
  category       Category?              @relation(fields: [categoryId], references: [id])
  images         ProductImage[]
  tags           Tag[]                  @relation("ProductTags")
  translations   ProductTranslation[]
  customizations ProductCustomization[]
  lineItems      OrderLineItem[]
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @default(now()) @updatedAt
}

model ProductTranslation {
  id          String  @id @default(cuid())
  locale      String // es, cat
  name        String
  description String?
  productId   String
  product     Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, locale])
}

model ProductCustomization {
  id        String   @id @default(cuid())
  text      String?
  color     String?
  size      String?
  imageUrl  String?
  productId String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id])
}

model Order {
  id        String          @id @default(cuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id])
  sellerId  String
  seller    Seller          @relation(fields: [sellerId], references: [id])
  status    String          @default("PENDING")
  total     Decimal
  // Source cart id when the order was created by HandleCartCheckedOut
  // (spec REQ-ORD-001). Used for idempotency: the handler dedupes by
  // cartId so duplicate CART_CHECKED_OUT deliveries do not create a
  // second set of orders. Null for orders not created from a cart.
  cartId    String?
  lineItems OrderLineItem[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([cartId])
}

model OrderLineItem {
  id                    String   @id @default(cuid())
  orderId               String
  order                 Order    @relation(fields: [orderId], references: [id])
  productId             String
  product               Product  @relation(fields: [productId], references: [id])
  quantity              Int
  customizationText     String?
  customizationColor    String?
  customizationSize     String?
  customizationImageUrl String?
  createdAt             DateTime @default(now())
}

model SignupAttempt {
  id        String   @id @default(cuid())
  ipAddress String
  email     String
  createdAt DateTime @default(now())

  @@index([ipAddress, createdAt])
}

model LoginAttempt {
  id        String   @id @default(cuid())
  email     String
  ipAddress String?
  success   Boolean
  createdAt DateTime @default(now())

  @@index([email, createdAt])
  @@index([ipAddress, createdAt])
}

model EmailQueue {
  id          String    @id @default(cuid())
  to          String
  subject     String
  htmlBody    String
  template    String?
  metadata    Json?
  status      String    @default("PENDING")
  error       String?
  retryCount  Int       @default(0)
  maxRetries  Int       @default(3)
  scheduledAt DateTime  @default(now())
  sentAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, scheduledAt])
  @@index([createdAt])
}

model OutboxEvent {
  id          String    @id @default(cuid())
  eventType   String
  payload     Json
  status      String    @default("PENDING")
  // PENDING, PROCESSED, FAILED
  createdAt   DateTime  @default(now())
  processedAt DateTime?
}

model ProductImage {
  id        String   @id @default(cuid())
  url       String
  alt       String?
  position  Int
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([productId, position])
}

enum UploadType {
  product
  avatar
  ticket
  general
}

enum UploadStatus {
  PENDING
  CONFIRMED
}

enum CartStatus {
  ACTIVE
  CHECKED_OUT
}

model Cart {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id])
  status    CartStatus @default(ACTIVE)
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([userId, status])
}

model CartItem {
  id                    String   @id @default(cuid())
  cartId                String
  cart                  Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId             String
  sellerId              String
  quantity              Int
  unitPriceSnapshot     Decimal
  customizationText     String?
  customizationColor    String?
  customizationSize     String?
  customizationImageUrl String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([cartId])
  @@index([productId])
}

model Tag {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  products  Product[] @relation("ProductTags")
  createdAt DateTime  @default(now())
}

model Category {
  id        String     @id @default(cuid())
  name      String
  slug      String     @unique
  parentId  String?
  parent    Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryHierarchy")
  products  Product[]
  createdAt DateTime   @default(now())

  @@index([parentId])
}

model Upload {
  id         String   @id @default(cuid())
  fileName   String
  storageKey String   @unique
  mimeType   String
  size       Int
  uploadedBy String
  type       UploadType
  status     UploadStatus @default(PENDING)
  createdAt  DateTime @default(now())

  @@index([uploadedBy])
  @@index([type, status])
  @@index([status, createdAt]) // orphan cleanup query
}
