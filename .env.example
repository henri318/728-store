# Database (PostgreSQL via Docker on port 5433)
DATABASE_URL=postgresql://testuser:testpassword@localhost:5433/testdb

# NextAuth
NEXTAUTH_SECRET=your-secret-here-generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Public app URL (needed during build)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: Google OAuth (leave empty to disable Google login)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
